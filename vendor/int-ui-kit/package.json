{
  "name": "@jetbrains/int-ui-kit",
  "version": "0.3.0",
  "description": "JetBrains Int UI Kit — React component library for building JetBrains-style IDE prototypes",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "src/lib/index.d.ts",
  "files": [
    "dist",
    "src/lib/index.d.ts",
    "src/stories",
    "src/ui",
    "docs"
  ],
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./src/lib/index.d.ts"
    },
    "./styles.css": "./dist/esm/styles.css"
  },
  "sideEffects": [
    "*.css",
    "./src/ui/components/editor/registerGrammars.js"
  ],
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "prism-react-editor": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.12.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "storybook dev -p 6006",
    "start:showcase": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate:icons": "node scripts/generateIconRegistry.js",
    "generate:tokens": "node scripts/generateTokens.js",
    "build:lib": "npm run generate:icons && rollup -c rollup.config.mjs",
    "prepublishOnly": "npm run build:lib"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-onboarding": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@svgr/rollup": "^8.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "prop-types": "^15.8.1",
    "rollup": "^2.80.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "storybook": "^10.3.3",
    "storybook-addon-pseudo-states": "^10.3.5",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-svgr": "^4.5.0"
  }
}
